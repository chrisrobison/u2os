    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "mysql2": "^3.14.0",
    "pg": "^8.13.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "ws": "^8.20.0"
  },
  "overrides": {
    "tar": "^7.5.10",
    "@tootallnate/once": "^3.0.1"
