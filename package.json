{
  "name": "u2os",
  "version": "0.1.0",
  "description": "U2OS: API-first operating system for modern service businesses",
  "main": "core/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node core/server.js",
    "dev": "node --watch core/server.js",
