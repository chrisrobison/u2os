PORT=3010
DB_CLIENT=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=u2os
DB_FILE=./data/u2os.sqlite
CONTROL_DB_CLIENT=sqlite
CONTROL_DB_HOST=127.0.0.1
CONTROL_DB_PORT=3306
CONTROL_DB_USER=root
CONTROL_DB_PASSWORD=password
CONTROL_DB_NAME=u2os_control
CONTROL_DB_FILE=./data/u2os-control.sqlite
TENANCY_MODE=local
TENANCY_STRICT_HOST_MATCH=false
TENANCY_BOOTSTRAP_HOST=localhost
TENANCY_BOOTSTRAP_DOMAIN=localhost
TENANCY_ALLOW_OVERRIDE=false
TENANCY_OVERRIDE_HEADER=x-tenant-id
TENANCY_OVERRIDE_QUERY_PARAM=tenant_id
AUTH_JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
AUTH_TOKEN_TTL_SECONDS=28800
ADMIN_BOOTSTRAP_EMAIL=admin@localhost
ADMIN_BOOTSTRAP_PASSWORD=admin12345678
ADMIN_BOOTSTRAP_NAME=Install Admin
ADMIN_BOOTSTRAP_ROLE=owner
MODULES_DIR=modules
SETTINGS_GLOBAL_FILE=config/settings.json
CLIENTS_DIR=clients
TRUST_PROXY=false
TENANCY_TRUST_FORWARDED_HOST=false
CORS_ALLOWLIST=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
API_BODY_LIMIT=1mb
AUTH_BODY_LIMIT=32kb
REALTIME_ENABLED=true
REALTIME_PATH=/ws/events
REALTIME_REPLAY_LIMIT=200
REALTIME_BACKLOG_SIZE=2000
REALTIME_MAX_SUBSCRIPTIONS=32
MIGRATIONS_STRICT_STARTUP=true
