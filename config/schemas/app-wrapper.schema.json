{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://u2os.local/schemas/app-wrapper.schema.json",
  "title": "U2OS Solution",
  "description": "Composable solution manifest (legacy filename: app-wrapper schema).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "app",
    "modules"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "2026-03-14"
    },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "description": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./module.schema.json"
      }
    },
    "processCatalog": {
      "type": "array",
      "items": {
        "$ref": "./process.schema.json"
      }
    },
    "templateCatalog": {
      "type": "array",
      "items": {
        "$ref": "./template.schema.json"
      }
    }
  }
}
