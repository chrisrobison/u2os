      "title": "Insurance Claims",
      "order": 0,
      "template": { "id": "dental.workspace.insurance-claims" },
      "tags": ["insurance-claims"],
      "hooks": {
        "onLoad": [
          { "type": "server", "name": "server.auditView", "options": { "area": "insurance-claims" } }
        ],
        "afterSave": [
          { "type": "server", "name": "server.auditSave", "options": { "area": "insurance-claims" } }
        ]
      }
    },
    {
      "schemaVersion": "2026-03-14",
      "id": "dental-invoices",
      "moduleId": "billing",
      "title": "Invoices",
      "order": 1,
      "template": { "id": "dental.workspace.invoices" }
