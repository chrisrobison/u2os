    },
    {
      "schemaVersion": "2026-03-14",
      "id": "dental-procedures",
      "moduleId": "clinical",
      "title": "Procedures",
      "order": 3,
      "template": { "id": "dental.workspace.procedures" }
    },
    {
      "schemaVersion": "2026-03-14",
      "id": "dental-claims",
